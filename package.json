{
  "name": "snakeconverter",
  "version": "1.0.0",
  "description": "Browser-based PDF toolkit with snake mascot",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "dev": "npx serve . -p 3000",
    "sitemap": "node scripts/generate-sitemap.cjs",
    "seo": "node scripts/generate-micro-pages.cjs && node scripts/generate-sitemap.cjs",
    "seo:qa": "node scripts/seo-duplicate-titles.cjs && node scripts/seo-micro-integrity.cjs",
    "seo:faz5:preflight": "node scripts/seo-faz5-preflight.cjs",
    "ship:qa": "node scripts/ship-check.cjs"
  },
  "devDependencies": {
    "javascript-obfuscator": "^4.1.1",
    "terser": "^5.36.0",
    "fs-extra": "^11.3.0"
  }
}
